# Copy this file to .env and fill in real values. Never commit .env itself
# (it's already in .gitignore).
#
# These power the /api/contact endpoint, which sends the contact form
# submissions by email via SMTP.
#
# Easiest option: a Gmail account with an "App Password"
# (Google Account → Security → 2-Step Verification → App passwords).
# Regular Gmail passwords will NOT work here — it must be an app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

---
import '../styles/global.css';
import { siteConfig } from '../data/site.config.js';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Saanvi — Kids Modelling Portfolio',
  description = `${siteConfig.profile.ageRange} · ${siteConfig.profile.location}`,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Open Graph / social preview -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="/og-image-v1.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="/og-image-v1.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <slot />

  <!-- Web3Forms hCaptcha widget (used by ContactForm.astro) -->
  <script src="https://web3forms.com/client/script.js" async defer></script>

  <script>
    // Scroll-reveal: fade/slide sections and photo blocks in as they enter view.
    document.addEventListener('DOMContentLoaded', () => {
      const revealEls = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      }
    });

    // Scroll-linked section transitions: as each full-viewport section is
    // scrolled past, its content gracefully fades and lifts away while the
    // next section's content simultaneously settles into place — driven
    // entirely by scroll position (the same technique already used for the
    // carousel's horizontal movement), never by a fixed-speed canned
    // animation. This never calls preventDefault or scrollTo — it only
    // reads scroll position and applies a transform in response — so it
    // can't get "stuck" and works identically with mouse, trackpad, or touch.
    document.addEventListener('DOMContentLoaded', () => {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      // The fade/lift window is set to exactly half the viewport height.
      // Since every full-viewport section is exactly 100vh tall, this makes
      // the outgoing section's fade-out complete at precisely the same
      // scroll position where the incoming section's fade-in begins — a
      // seamless handoff with no gap where both are invisible, and no
      // "dead" extra scroll distance added anywhere.
      let budget = window.innerHeight / 2;
      const lift = 56;
      const clamp = (v, min, max) => Math.min(Math.max(v, min), max);
      const navEl = document.querySelector('header.nav');
      const navOffset = () => (navEl ? navEl.offsetHeight : 0);

      // Easing applied to the raw (linear) progress before it drives
      // opacity/transform. A pure power curve keeps the endpoints fixed at
      // 0 and 1 — so the gap-free handoff between adjacent sections is
      // unaffected — while reshaping the middle: entrance reaches full
      // opacity quickly and then holds, exit holds at full opacity and
      // only drops quickly right at the end. Net effect: content spends
      // more of the scroll fully visible, with the fade concentrated in a
      // shorter window at each boundary rather than spread across the
      // whole transition. Raise EASE_POWER for an even snappier feel.
      const EASE_POWER = 2.5;
      const easeIn = (v) => Math.pow(v, 1 / EASE_POWER);
      const easeOut = (w) => Math.pow(w, EASE_POWER);

      // Sections with their own extra scroll budget: fade+lift out at the
      // end (exit), fade+settle in at the start (entrance) — both driven
      // by the same outer element's position, so no cross-element state.
      const panels = Array.from(document.querySelectorAll('.slide-panel')).map((panel) => ({
        panel,
        inner: panel.querySelector(':scope > .slide-exit-inner'),
      })).filter((p) => p.inner);

      // Elements with an entrance-only fade (footer, the carousel) — no
      // budget of their own, they simply settle in as they scroll up from
      // below, then stay put.
      const fadeIns = Array.from(document.querySelectorAll('.slide-fade-in'));

      function updatePanel({ panel, inner }) {
        const top = panel.getBoundingClientRect().top - navOffset();
        let opacity;
        let translateY;
        if (top >= 0) {
          const v = easeIn(clamp(1 - top / budget, 0, 1));
          opacity = v;
          translateY = (1 - v) * lift;
        } else {
          const w = easeOut(clamp(-top / budget, 0, 1));
          opacity = 1 - w;
          translateY = -w * lift;
        }
        inner.style.opacity = String(opacity);
        inner.style.transform = `translateY(${translateY}px)`;
      }

      function updateFadeIn(el) {
        const top = el.getBoundingClientRect().top - navOffset();
        const v = easeIn(clamp(1 - top / budget, 0, 1));
        el.style.opacity = String(v);
        el.style.transform = `translateY(${(1 - v) * lift}px)`;
      }

      let ticking = false;
      function update() {
        panels.forEach(updatePanel);
        fadeIns.forEach(updateFadeIn);
        ticking = false;
      }
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      }

      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', () => {
        budget = window.innerHeight / 2;
        update();
      });
    });
  </script>
</body>
</html>

---
import { siteConfig } from '../data/site.config.js';
const carouselItems = siteConfig.gallery.filter((item) => item.orientation !== 'landscape');
---
<section id="carousel-pin-outer" class="carousel-pin-outer reveal">
  <div id="carousel-pin-inner" class="carousel-pin-inner">
    <div class="carousel-wrap">
      <button class="carousel-arrow carousel-arrow--prev" type="button" aria-label="Scroll to previous photo">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="carousel-track" id="carousel-track">
        {carouselItems.map((item) => (
          <figure class:list={['carousel-card', { 'carousel-card--placeholder': item.placeholder }]}>
            {item.placeholder ? (
              <div class="carousel-frame placeholder">
                <span>More photos<br />coming soon</span>
              </div>
            ) : (
              <div class="carousel-frame">
                <img src={item.src} alt={item.alt} loading="lazy" />
              </div>
            )}
            <figcaption>
              <span class="cap-index">{item.index}</span>
              <span class="cap-title">{item.caption}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      <button class="carousel-arrow carousel-arrow--next" type="button" aria-label="Scroll to next photo">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  // Scroll-linked "pin" carousel: normal page scroll the whole time, no wheel
  // hijacking. While this section is scrolling past, it holds in place
  // (position: sticky) and the track slides horizontally in proportion to
  // scroll position; once it's exhausted, the section un-sticks and the
  // page keeps scrolling normally. On narrow screens or when the visitor
  // prefers reduced motion, it falls back to a plain native-scroll carousel.
  const outer = document.getElementById('carousel-pin-outer');
  const inner = document.getElementById('carousel-pin-inner');
  const track = document.getElementById('carousel-track');
  const prevBtn = document.querySelector('.carousel-arrow--prev');
  const nextBtn = document.querySelector('.carousel-arrow--next');

  const canPin = () =>
    window.matchMedia('(min-width: 900px)').matches &&
    window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  let pinEnabled = false;
  let maxScroll = 0;
  let ticking = false;

  const cardStep = () => {
    const card = track.querySelector('.carousel-card');
    return card ? card.getBoundingClientRect().width + 24 : 320;
  };

  function measure() {
    pinEnabled = canPin();

    if (!pinEnabled) {
      outer.style.height = '';
      track.style.transform = '';
      track.classList.add('carousel-track--native');
      return;
    }

    track.classList.remove('carousel-track--native');
    maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
    outer.style.height = `${inner.offsetHeight + maxScroll}px`;
  }

  function onScroll() {
    if (!pinEnabled || maxScroll <= 0) return;
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const rect = outer.getBoundingClientRect();
      const scrolled = -rect.top;
      const progress = Math.min(Math.max(scrolled / maxScroll, 0), 1);
      track.style.transform = `translateX(-${progress * maxScroll}px)`;
      ticking = false;
    });
  }

  if (outer && inner && track) {
    measure();
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      measure();
      onScroll();
    });
    window.addEventListener('load', () => {
      measure();
      onScroll();
    });

    prevBtn?.addEventListener('click', () => {
      if (pinEnabled) {
        window.scrollBy({ top: -cardStep(), behavior: 'smooth' });
      } else {
        track.scrollBy({ left: -cardStep(), behavior: 'smooth' });
      }
    });
    nextBtn?.addEventListener('click', () => {
      if (pinEnabled) {
        window.scrollBy({ top: cardStep(), behavior: 'smooth' });
      } else {
        track.scrollBy({ left: cardStep(), behavior: 'smooth' });
      }
    });
  }
</script>

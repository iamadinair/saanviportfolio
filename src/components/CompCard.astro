---
import { siteConfig } from '../data/site.config.js';
---
<section id="compcard-section">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">For casting directors</p>
      <h2 id="compcard">Comp card</h2>
    </div>
    <div class="compcard-box reveal">
      <p>One page, ready to download and pass along.</p>
      <a class="btn" href={siteConfig.compCardPdfPath} download>Download comp card</a>
    </div>
  </div>
</section>

---
import { siteConfig } from '../data/site.config.js';
const landscapeItems = siteConfig.gallery.filter((item) => item.orientation === 'landscape');
---
{landscapeItems.map((item) => (
  <section id={`gallery-${item.index}`} class="photo-block-section reveal">
    <figure class="photo-block photo-block--landscape">
      <div class="photo-block-frame">
        <img src={item.src} alt={item.alt} />
      </div>
      <figcaption>
        <span class="cap-index">{item.index}</span>
        <span class="cap-title">{item.caption}</span>
      </figcaption>
    </figure>
  </section>
))}

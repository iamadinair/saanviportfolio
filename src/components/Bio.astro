---
import { siteConfig } from '../data/site.config.js';
const { profile } = siteConfig;
const temperamentLine = profile.temperamentNotes
  .slice(0, 2)
  .map((n) => n.toLowerCase())
  .join(' and ');
---
<section id="about">
  <div class="container about-wrap reveal">
    <p class="eyebrow">About</p>
    <p class="bio">
      I'm <span>{profile.name}</span>, <span>{profile.ageRange}</span> old and based in
      <span>{profile.location}</span>. I stand at <span>{profile.stats.height}</span> tall,
      weigh <span>{profile.stats.weight}</span>, and wear size <span>{profile.stats.clothingSize}</span> clothing, with
      <span>{profile.stats.eyeColour.toLowerCase()}</span> eyes and <span>{profile.stats.hairColour.toLowerCase()}</span> hair. I'm
      <span>{temperamentLine}</span>. Managed by my parents — always happy to hear from
      agencies and photographers looking to collaborate.
    </p>
  </div>
</section>
